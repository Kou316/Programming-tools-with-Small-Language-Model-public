import os, torch
from transformers import AutoTokenizer, AutoModelForCausalLM, TrainingArguments, Trainer
from datasets import load_dataset
import evaluate
from peft import LoraConfig, get_peft_model, TaskType
from transformers import Trainer, TrainingArguments

from google.colab import files
uploaded = files.upload()

MODEL_NAME = "elyza/ELYZA-japanese-Llama-2-7b-instruct"
OUTPUT_DIR = "./elyza_fft"
TRAIN_FILE = "elyza_train.jsonl"
VALIDATION_FILE = "elyza_val.jsonl"

MAX_SEQ_LENGTH = 512

LEARNING_RATE = 2e-5
PER_DEVICE_BATCH_SIZE = 4
GRADIENT_ACCUMULATION_STEPS = 4
NUM_EPOCHS = 1 

is_cuda_available = torch.cuda.is_available()
device = torch.device("cuda" if is_cuda_available else "cpu")
is_bf16_available = is_cuda_available and torch.cuda.get_device_capability()[0] >= 8

print(f"実質バッチサイズ: {PER_DEVICE_BATCH_SIZE * GRADIENT_ACCUMULATION_STEPS}")

def format_data(sample):
    """
    JSONデータを、シンプルなInstruction Tuning形式に整形する。
    Input = Instructionフィールドの値のみ
    Target = 【問題文】から始まる構造化テキスト
    """
    instruction = sample["instruction"]

    output_format = sample["output_format"]

    target_text = f"""【問題文】\n{output_format['problem_text']}\n【入力】\n{output_format['input_spec']}\n【出力】\n{output_format['output_spec']}\n【入力例】\n{output_format['example_input']}\n【出力例】\n{output_format['example_output']}"""

    input_text = instruction

    full_sequence = input_text + target_text

def tokenize_function(examples):
    full_tokenized = tokenizer(
        examples["full_sequence"], max_length=MAX_SEQ_LENGTH, truncation=True, padding="max_length"
    )
    input_tokenized = tokenizer(
        examples["input"], max_length=MAX_SEQ_LENGTH, truncation=True, padding=False
    )

    labels = full_tokenized["input_ids"].copy()

    prompt_length = len(input_tokenized["input_ids"])
    labels[:prompt_length] = [-100] * prompt_length

    full_tokenized["labels"] = labels

    return full_tokenized

tokenized_train_dataset = train_dataset.map(tokenize_function, batched=False, remove_columns=train_dataset.column_names)
tokenized_eval_dataset = eval_dataset.map(tokenize_function, batched=False, remove_columns=eval_dataset.column_names)

print(f"学習データ数: {len(tokenized_train_dataset)}")
print(f"検証データ数: {len(tokenized_eval_dataset)}")
    return {"input": input_text, "target": target_text, "full_sequence": full_sequence}

print("データセットのロードと整形を開始...")

print("モデルのロードとLoRA設定中...")

dtype = torch.bfloat16 if is_bf16_available else torch.float16

model = AutoModelForCausalLM.from_pretrained(
    MODEL_NAME,
    torch_dtype=dtype,
    device_map="auto"
)
train_dataset = load_dataset("json", data_files=TRAIN_FILE, split="train").map(format_data, batched=False)
eval_dataset = load_dataset("json", data_files=VALIDATION_FILE, split="train").map(format_data, batched=False)

tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

training_args = TrainingArguments(
    output_dir=OUTPUT_DIR,
    num_train_epochs=NUM_EPOCHS,
    per_device_train_batch_size=PER_DEVICE_BATCH_SIZE,
    gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,
    learning_rate=LEARNING_RATE,
    warmup_ratio=0.03,
    logging_steps=10,
    save_total_limit=1,
    save_steps=500,
    save_strategy="steps",
    eval_strategy="steps",
    eval_steps=100,
    load_best_model_at_end=True,
    metric_for_best_model="eval_loss",
    save_only_model=True,
    fp16=not is_bf16_available,
    bf16=is_bf16_available,
    optim="adamw_torch",
    max_grad_norm=1.0,
    report_to="none",
)

trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=tokenized_train_dataset,
    eval_dataset=tokenized_eval_dataset,
)

trainer.train()

print(trainer.evaluate())

trainer.save_model("./elyza_full_ft")
tokenizer.save_pretrained("./elyza_full_ft")

# write file path
model.save_pretrained("")
tokenizer.save_pretrained("")
