import json
import torch
from datasets import load_dataset
from transformers import AutoModelForCausalLM, AutoTokenizer, TrainingArguments, Trainer
from transformers import DataCollatorForLanguageModeling
import os, gc, shutil

MODEL_NAME = "bigcode/starcoder2-7b"
OUTPUT_DIR = "./sc2_full_ft"
TRAIN_FILE = "scb_train.jsonl"
VALIDATION_FILE = "scb_val.jsonl"

MAX_SEQ_LENGTH = 2048

LEARNING_RATE = 5e-6
PER_DEVICE_BATCH_SIZE = 1
GRADIENT_ACCUMULATION_STEPS = 16
NUM_EPOCHS = 3

is_cuda_available = torch.cuda.is_available()
device = torch.device("cuda" if is_cuda_available else "cpu")
is_bf16_available = is_cuda_available and torch.cuda.get_device_capability()[0] >= 8

print(f"実質バッチサイズ: {PER_DEVICE_BATCH_SIZE * GRADIENT_ACCUMULATION_STEPS}")

def format_data_for_starcoder(sample):
    """
    オリジナルのJSON構造を、StarCoder2学習用の「prompt」と「response」に整形する。
    """

    prompt = {
        "topic": sample["topic"],
        "difficulty": sample["difficulty"],
        "language": sample["language"],
        "problem_specification": sample["input_prompt"].strip(),
        "response_format": {
            "code": "Wait for the generated code",
            "testcases": [
                {
                    "input": "Test input",
                    "output": "Expected output"
                }
            ]
        }
    }
    import json
    response = {
        "code": sample["code"].strip(),
        "testcases": [ # key: test_cases -> testcases
            {
                "input": tc["input"].strip(),
                "output": tc["expected_output"].strip()
            } for tc in sample["test_cases"]
        ]
    }

    prompt_json = json.dumps(prompt, ensure_ascii=False)
    response_json = json.dumps(response, ensure_ascii=False)

    input_text = f"### Input:\n{prompt_json}\n\n### Response:\n"

    full_sequence = input_text + response_json

    return {
        "input": input_text,
        "target": response_json,
        "full_sequence": full_sequence
    }

def tokenize_function(examples):
    """
    整形されたテキストをトークナイズし、ラベルを設定する。
    プロンプト部分のラベルを-100にして、学習時に損失を計算しないようにする（Instruction Tuning用）。
    また、確実にEOSトークンを学習させることで、生成の停止を安定させる。
    """
    input_ids_list = []
    attention_mask_list = []
    labels_list = []

    for prompt, full_seq in zip(examples["input"], examples["full_sequence"]):

        if tokenizer.eos_token and not full_seq.endswith(tokenizer.eos_token):
            full_seq = full_seq + tokenizer.eos_token

        tokenized_full = tokenizer(
            full_seq,
            truncation=True,
            max_length=MAX_SEQ_LENGTH,
            padding=False,
            add_special_tokens=True
        )

        tokenized_prompt = tokenizer(
            prompt,
            truncation=True,
            max_length=MAX_SEQ_LENGTH,
            padding=False,
            add_special_tokens=True
        )

        input_ids = tokenized_full["input_ids"]
        attention_mask = tokenized_full["attention_mask"]
        labels = list(input_ids) # コピーを作成

        prompt_len = len(tokenized_prompt["input_ids"])

        if prompt_len > len(labels):
            prompt_len = len(labels)

        for i in range(prompt_len):
            labels[i] = -100
        pad_len = MAX_SEQ_LENGTH - len(input_ids)
        if pad_len > 0:
            input_ids += [tokenizer.pad_token_id] * pad_len
            attention_mask += [0] * pad_len
            labels += [-100] * pad_len

        input_ids_list.append(input_ids)
        attention_mask_list.append(attention_mask)
        labels_list.append(labels)

    return {
        "input_ids": input_ids_list,
        "attention_mask": attention_mask_list,
        "labels": labels_list
    }

print("データセットのロードと整形を開始...")
train_dataset = load_dataset("json", data_files=TRAIN_FILE, split="train").map(format_data_for_starcoder, batched=False)
eval_dataset = load_dataset("json", data_files=VALIDATION_FILE, split="train").map(format_data_for_starcoder, batched=False)
print(f"訓練データセットのサイズ: {len(train_dataset)}")
print("-" * 30)

print(f"トークナイザーのロードを開始 ({MODEL_NAME})...")
tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
print("トークナイザーのロード完了。")
print("-" * 30)

print("データセットのロードと整形を開始...")
train_dataset = load_dataset("json", data_files=TRAIN_FILE, split="train").map(format_data_for_starcoder, batched=False)
eval_dataset = load_dataset("json", data_files=VALIDATION_FILE, split="train").map(format_data_for_starcoder, batched=False)
print(f"訓練データセットのサイズ: {len(train_dataset)}")
print("-" * 30)


print(f"トークナイザーのロードを開始 ({MODEL_NAME})...")
tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
print("トークナイザーのロード完了。")
print("-" * 30)

print("トークナイズ処理を適用...")
cols_to_remove = ['input', 'target', 'full_sequence', 'topic', 'difficulty', 'language', 'input_prompt', 'code', 'test_cases', 'model_used']
tokenized_train_dataset = train_dataset.map(
    tokenize_function,
    batched=True,
    remove_columns=[col for col in cols_to_remove if col in train_dataset.column_names]
)
tokenized_eval_dataset = eval_dataset.map(
    tokenize_function,
    batched=True,
    remove_columns=[col for col in cols_to_remove if col in eval_dataset.column_names]
)

print(f"トークナイズ後の訓練データセット: {tokenized_train_dataset}")
print("-" * 30)
print("データ準備ステップが完了しました。")

import torch
import gc
import shutil
import os

required_vars = ["tokenized_train_dataset", "tokenized_eval_dataset", "tokenizer"]
missing_vars = [v for v in required_vars if v not in globals()]
if missing_vars:
    raise RuntimeError(f"エラー: 以下の変数が定義されていません: {', '.join(missing_vars)}。\n"
                       "データセットのロード・整形・トークナイズを行う上のセルをすべて実行してください。")

if os.path.exists(OUTPUT_DIR):
    print(f"ディスク容量確保のため、既存のディレクトリ {OUTPUT_DIR} を削除します...")
    shutil.rmtree(OUTPUT_DIR)

print(f"モデルのロードを開始 ({MODEL_NAME})...")

if 'model' in globals():
    del model
if 'trainer' in globals():
    del trainer
gc.collect()
torch.cuda.empty_cache()

model = AutoModelForCausalLM.from_pretrained(
    MODEL_NAME,
    device_map={"": 0},
    torch_dtype=torch.bfloat16 if is_bf16_available else torch.float16,
)

model.gradient_checkpointing_enable()

print("モデルロード完了 (Full parameters)。")
print("-" * 30)

training_args = TrainingArguments(
    output_dir=OUTPUT_DIR,
    per_device_train_batch_size=PER_DEVICE_BATCH_SIZE,
    gradient_accumulation_steps=GRADIENT_ACCUMULATION_STEPS,
    learning_rate=LEARNING_RATE,
    num_train_epochs=NUM_EPOCHS,
    logging_dir=f"{OUTPUT_DIR}/logs",
    logging_steps=10,

    save_strategy="epoch",
    save_total_limit=1,

    eval_strategy="epoch",
    bf16=is_bf16_available,
    fp16=not is_bf16_available,
    push_to_hub=False,
    report_to="none",
    gradient_checkpointing=True,
    optim="paged_adamw_32bit",
    warmup_ratio=0.1,
    weight_decay=0.01,
    seed=42
)

trainer = Trainer(
    model=model,
    args=training_args,
    train_dataset=tokenized_train_dataset,
    eval_dataset=tokenized_eval_dataset,
    tokenizer=tokenizer,
    data_collator=DataCollatorForLanguageModeling(tokenizer, mlm=False)
)

import torch

torch.cuda.empty_cache()
print("\n--- LoRA ファインチューニング開始 ---")
trainer.train()

print(trainer.evaluate())

trainer.save_model(OUTPUT_DIR)
tokenizer.save_pretrained(OUTPUT_DIR)

# write your save path
model.save_pretrained("")
tokenizer.save_pretrained("")
