import os, re, uuid, json, random, tempfile, subprocess, ast
from typing import Any, Dict, List, Optional
from fastapi import FastAPI
from fastapi.responses import JSONResponse
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
from transformers import AutoModelForCausalLM, AutoTokenizer
import torch

# ===== Config =====
DEVICE = "cuda" if torch.cuda.is_available() else "cpu"
DTYPE = torch.float16 if DEVICE == "cuda" else torch.float32
ELYZA_MODEL_ID = "/content/drive/MyDrive/models10/elyza_full_ft"
SCB_MODEL_ID   = "/content/drive/MyDrive/models10/sc2_fft2"
SCB_GEN_MAX_NEW_TOKENS = 600
SCB_GEN_MAX_TIME = 60
SCB_GEN_TEMP = 0.1
SCB_GEN_TOP_P = 0.95
MAX_RETRIES = 3

PROBLEMS_PATH  = os.getenv(
    "PROBLEMS_FILE_PATH",
    "/content/drive/MyDrive/graduate-research/my-react-app/public/problems_eval.jsonl",
)
CODE_EVAL_PATH = os.getenv(
    "CODE_EVAL_FILE_PATH",
    "/content/drive/MyDrive/graduate-research/my-react-app/public/code_eval.jsonl",
)
os.makedirs(os.path.dirname(PROBLEMS_PATH), exist_ok=True)
os.makedirs(os.path.dirname(CODE_EVAL_PATH), exist_ok=True)

# ===== Load Models =====
elyza_tokenizer = AutoTokenizer.from_pretrained(ELYZA_MODEL_ID)
elyza_model = AutoModelForCausalLM.from_pretrained(ELYZA_MODEL_ID, torch_dtype=DTYPE, device_map="auto")
scb_tokenizer = AutoTokenizer.from_pretrained(SCB_MODEL_ID)
scb_model = AutoModelForCausalLM.from_pretrained(SCB_MODEL_ID, torch_dtype=DTYPE, device_map="auto")

# ===== FastAPI app =====
app = FastAPI()
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# ===== Pydantic Schemas =====
class ProblemRequest(BaseModel):
    topic: str
    difficulty: str = "標準"

class ProblemAppend(BaseModel):
    topic: str
    difficulty: int | str
    problem_text: str
    input_spec: Optional[str] = None
    output_spec: Optional[str] = None
    example_input: Optional[str] = None
    example_output: Optional[str] = None
    source: Optional[str] = None

class CodeRequest(BaseModel):
    problem_text: str
    input_spec: Optional[str] = None
    output_spec: Optional[str] = None
    example_input: Optional[str] = None
    example_output: Optional[str] = None
    language: str = "python"

class RunRequest(BaseModel):
    code: str
    language: str = "python"
    testcases: List[Dict[str, str]] = []
    input_data: Optional[str] = None

# ===== Helpers =====
def simple_id(topic: str, difficulty: int | str, body: str) -> str:
    base = f"{topic}|{difficulty}|{body}"
    try:
        h = 0
        for ch in base.encode("utf-8"):
            h = (h * 31 + ch) & 0xFFFFFFFF
        return f"p_{h:08x}"
    except Exception:
        return f"p_{uuid.uuid4().hex[:8]}"

def append_problem(record: dict):
    line = json.dumps(record, ensure_ascii=False)
    with open(PROBLEMS_PATH, "a", encoding="utf-8") as f:
        f.write(line + "\n")

def append_code_eval(record: dict):
    line = json.dumps(record, ensure_ascii=False)
    with open(CODE_EVAL_PATH, "a", encoding="utf-8") as f:
        f.write(line + "\n")

def pick_random_theme(_: str):
    return None, None

def cut_output_examples(text: str) -> str:
    return text

def build_problem_payload(
    *,
    topic: str,
    difficulty: int | str,
    problem_text: str,
    input_spec: Optional[str] = None,
    output_spec: Optional[str] = None,
    example_input: Optional[str] = None,
    example_output: Optional[str] = None,
    source: Optional[str] = None,
    task_type: str = "problem_generation",
) -> Dict[str, Any]:
    def nz(v: Optional[str]) -> str:
        return v if v is not None else ""
    output_format = {
        "problem_text": nz(problem_text),
        "input_spec": nz(input_spec),
        "output_spec": nz(output_spec),
        "example_input": nz(example_input),
        "example_output": nz(example_output),
    }
    return {
        "task_type": task_type,
        "topic": topic,
        "difficulty": difficulty,
        "problem_text": nz(problem_text),
        "input_spec": nz(input_spec),
        "output_spec": nz(output_spec),
        "example_input": nz(example_input),
        "example_output": nz(example_output),
        "source": source,
        "output_format": output_format,
    }

# ===== SC2 extract =====
def clean_model_output(text: str) -> str:
    text = text.strip()

    # Note: We removed the footer-stripping logic because it was aggressively removing
    # valid JSON if the model hallucinated a new prompt (containing the footer) AFTER the answer.

    # Strip enclosing triple quotes if present
    if text.startswith('"""') and text.endswith('"""'):
        text = text[3:-3].strip()
    if text.startswith("'''") and text.endswith("'''"):
        text = text[3:-3].strip()

    # Remove ###Response artifact
    if text.startswith("###Response"):
        text = text[11:].strip()

    # 2. Remove leading/trailing markdown code blocks
    if text.startswith('```'):
        text = re.sub(r'^```\w*\s*', '', text)
    text = re.sub(r'\s*```$', '', text)

    return text

def find_json_block(text: str) -> Optional[Any]:
    decoder = json.JSONDecoder()
    idx = 0
    while idx < len(text):
        # Try to find start of object or array
        m = re.search(r'[\{\[]', text[idx:])
        if not m: break
        start = idx + m.start()
        try:
            obj, end_idx = decoder.raw_decode(text, start)

            # Ignore the "template" JSON from the prompt if repeated
            if isinstance(obj, dict):
                if obj.get("code") == "ここにコードを記述":
                    idx = start + 1
                    continue

            return obj
        except json.JSONDecodeError:
            idx = start + 1
    return None

# ===== Endpoints =====
@app.post("/generate_problem")
def generate_problem(req: ProblemRequest):
    if elyza_model is None or elyza_tokenizer is None:
        return JSONResponse(status_code=500, content={"error": "Elyza model is not loaded."})
    theme_name, theme_desc = pick_random_theme(req.topic)
    theme_text = f"問題のテーマは「{theme_name}」です。" if theme_name else ""
    prompt = f"""
「{req.topic}」の{req.difficulty}に相当する問題を生成してください。
{theme_text}
"""
    inputs = elyza_tokenizer(prompt, return_tensors="pt")
    inputs = {k: v.to(DEVICE) for k, v in inputs.items()}
    outputs = elyza_model.generate(**inputs, max_new_tokens=1000, do_sample=True, temperature=0.7)
    text = elyza_tokenizer.decode(outputs[0], skip_special_tokens=True)
    problem_text = cut_output_examples(text).strip()
    return build_problem_payload(
        topic=req.topic,
        difficulty=req.difficulty,
        problem_text=problem_text,
        source="elyza",
    )

@app.post("/problems")
def add_problem(req: ProblemAppend):
    diff = req.difficulty
    try: diff = int(diff)
    except: pass
    pid = simple_id(req.topic, diff, req.problem_text)
    normalized = build_problem_payload(
        topic=req.topic,
        difficulty=diff,
        problem_text=req.problem_text,
        input_spec=req.input_spec,
        output_spec=req.output_spec,
        example_input=req.example_input,
        example_output=req.example_output,
        source=req.source or "elyza",
    )
    record = {"id": pid, **normalized}
    try:
        append_problem(record)
        return {"status": "ok", "id": pid, "path": PROBLEMS_PATH, **normalized}
    except Exception as e:
        return JSONResponse(status_code=500, content={"error": str(e)})

@app.post("/generate_code")
def generate_code(req: CodeRequest):
    lang_upper = req.language.upper()
    # Updated Prompt with markers
    prompt = f"""
###input
以下の問題と入出力仕様に基づき、**{lang_upper}**言語で解答コードを作成してください。
注意：このトピックでは関数を定義せず、トップレベルに直接ロジックを記述してください。
解答コードに加えて、問題文に示された例とは異なる**5つの新しいテストケース（入力と期待される出力）**を作成してください。

【問題】
{req.problem_text}

【出力形式】
必ず以下のJSON形式のみを出力してください。
{{
    "code": "ここにコードを記述",
    "test_cases": [
        {{"input": "入力例1", "output": "出力例1"}},
        {{"input": "入力例2", "output": "出力例2"}}
    ]
}}
全ての出力の最後に「【終了】」と出力してください。

###Response
"""
    inputs = scb_tokenizer(prompt, return_tensors="pt", truncation=True, max_length=500)
    inputs = {k: v.to(DEVICE) for k, v in inputs.items()}
    gen_kwargs = dict(
        max_new_tokens=SCB_GEN_MAX_NEW_TOKENS,
        do_sample=True,
        temperature=SCB_GEN_TEMP,
        top_p=SCB_GEN_TOP_P,
        max_time=SCB_GEN_MAX_TIME,
        early_stopping=True,
    )

    last_out_text = ""
    for attempt in range(MAX_RETRIES):
        try:
            with torch.inference_mode():
                outputs = scb_model.generate(**inputs, **gen_kwargs)
        except Exception as e:
            return JSONResponse(status_code=500, content={"error": f"SC2 generation failed: {e}"})

        # FIXED: inputs is a dict, so use ["input_ids"] instead of .input_ids
        input_len = inputs["input_ids"].shape[1]
        out_text = scb_tokenizer.decode(outputs[0][input_len:], skip_special_tokens=True).strip()
        last_out_text = out_text

        cleaned_text = clean_model_output(out_text)
        parsed_json = find_json_block(cleaned_text)

        if parsed_json is not None:
            # Normalize and include raw text for debugging
            if isinstance(parsed_json, dict):
                # normalize test_cases key names
                if 'testcases' in parsed_json and 'test_cases' not in parsed_json:
                    parsed_json['test_cases'] = parsed_json.get('testcases')
                parsed_json.setdefault('test_cases', parsed_json.get('test_cases', []))

                # Clean code field
                c = parsed_json.get('code', parsed_json.get('code_text',''))
                print(f"DEBUG_CLEANUP_BEFORE: {c!r}")

                # More aggressive cleanup: Remove any LINE containing "【終了】"
                c = re.sub(r'^.*【終了】.*\n?', '', c, flags=re.MULTILINE)

                parsed_json['code'] = c.strip()
                print(f"DEBUG_CLEANUP_AFTER: {parsed_json['code']!r}")

                parsed_json['raw_response'] = out_text
            return parsed_json

    # Fallback if no JSON found
    return JSONResponse(status_code=500, content={"error": "No valid JSON found in model output", "raw_response": last_out_text})

@app.post("/code_eval")
def add_code_eval(payload: Dict[str, Any]):
    rec_id = f"c_{uuid.uuid4().hex[:8]}"
    record = {"id": rec_id, **payload}
    try:
        append_code_eval(record)
        return {"status": "ok", "id": rec_id, "path": CODE_EVAL_PATH}
    except Exception as e:
        return JSONResponse(status_code=500, content={"error": str(e)})

@app.post("/run")
def run_code(req: RunRequest):
    if req.language.lower() != "python":
        return JSONResponse(status_code=400, content={"error": "Only python supported in Colab API5."})
    def exec_once(code: str, stdin_data: str):
        with tempfile.NamedTemporaryFile("w", suffix=".py", delete=False) as tf:
            tf.write(code)
            tf.flush()
            try:
                p = subprocess.run(
                    ["python3", tf.name],
                    input=stdin_data.encode("utf-8"),
                    stdout=subprocess.PIPE,
                    stderr=subprocess.PIPE,
                    timeout=10,
                )
                return p.stdout.decode("utf-8", errors="replace"), p.stderr.decode("utf-8", errors="replace")
            finally:
                try: os.unlink(tf.name)
                except: pass

    results = []
    passed_all = True
    if req.testcases:
        for tc in req.testcases:
            inp = tc.get("input", "") or tc.get("stdin", "") or ""
            expected = tc.get("expected") or tc.get("output") or ""
            out, err = exec_once(req.code, inp)
            results.append({
                "input": inp,
                "expected": expected,
                "stdout": out,
                "stderr": err,
                "pass": (expected.strip() == out.strip()) if expected else None,
            })
            if expected and expected.strip() != out.strip(): passed_all = False
        return {"passedAll": passed_all, "results": results}
    out, err = exec_once(req.code, req.input_data or "")
    return {"output": out, "error": err}

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)

